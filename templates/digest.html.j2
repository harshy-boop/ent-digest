<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ENT/Airway/Face Digest — May 15, 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F7F5EF;
    --surface: #ffffff;

    /* Forest-tinted borders */
    --border: #B8C9BC;
    --border-strong: #8FA897;
    --border-soft: #D5DFD5;
    --hairline: #E4EAE2;

    --text: #131A15;
    --text-mid: #3F4A42;
    --text-dim: #6E7A70;
    --text-faint: #A5AEA6;

    --forest: #1A4730;
    --forest-deep: #103022;
    --forest-mid: #2F6B49;
    --forest-soft: #57966F;
    --forest-tint: #E4ECE3;
    --forest-tint-strong: #D2DFD2;
    --forest-line: #98B49E;

    /* Score: green → red, more saturated */
    --s5-bg: #C5DFC8;  --s5-fg: #103022;  --s5-bd: #3F7A52;
    --s4-bg: #D9E2B8;  --s4-fg: #3D4D17;  --s4-bd: #7A8E43;
    --s3-bg: #F4E3A5;  --s3-fg: #5E4308;  --s3-bd: #C19E3A;
    --s2-bg: #F5C99A;  --s2-fg: #7A3712;  --s2-bd: #C57A39;
    --s1-bg: #F0A8A4;  --s1-fg: #6E141A;  --s1-bd: #B94D49;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  .mono { font-family: 'JetBrains Mono', monospace; }
  .serif { font-family: 'Source Serif 4', Georgia, serif; }

  .paper-grain {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      radial-gradient(circle at 25% 25%, rgba(26,71,48,0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 75%, rgba(26,71,48,0.03) 0%, transparent 55%);
  }

  header {
    position: sticky; top: 0; z-index: 50;
    border-bottom: 2px solid var(--forest);
    background: rgba(247,245,239,0.94);
    backdrop-filter: blur(10px);
  }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
  .header-inner { display: flex; align-items: center; justify-content: space-between; height: 80px; gap: 2rem; }
  .logo-block { display: flex; align-items: center; gap: 1rem; }
  .logo {
    width: 48px; height: 48px; border-radius: 8px;
    background: var(--forest-deep); color: #fff;
    display: flex; align-items: center; justify-content: center;
    border: 2px solid var(--forest);
  }
  .logo svg { width: 24px; height: 24px; }
  .brand-title {
    font-family: 'Source Serif 4', serif;
    font-size: 1.3rem; font-weight: 700; letter-spacing: -0.015em; color: var(--forest-deep);
  }
  .brand-sub {
    font-size: 0.625rem; font-weight: 700; letter-spacing: 0.28em;
    color: var(--forest-mid); text-transform: uppercase; margin-top: 3px;
  }
  .header-right { display: flex; align-items: center; gap: 1rem; }
  .status-pill {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.75rem; border: 1.5px solid var(--forest-line);
    border-radius: 6px; background: var(--forest-tint);
    font-size: 0.6875rem; color: var(--forest-deep); font-weight: 600;
  }
  .pulse-dot { width: 7px; height: 7px; background: var(--forest); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.4 } }

  main { position: relative; z-index: 10; padding: 3rem 0 5rem; }

  /* Report head */
  .report-head {
    border-bottom: 2px solid var(--forest);
    padding-bottom: 2.5rem; margin-bottom: 3rem;
    display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between; align-items: flex-end;
  }
  .head-status {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--forest-deep); margin-bottom: 1.25rem;
    padding: 0.3rem 0.75rem 0.3rem 0.55rem;
    background: var(--forest-tint); border: 1.5px solid var(--forest-line);
    border-radius: 999px;
  }
  .head-status-text {
    font-size: 0.625rem; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .head-title {
    font-family: 'Source Serif 4', serif;
    font-size: 3.25rem; font-weight: 700; letter-spacing: -0.025em;
    line-height: 1.02; margin-bottom: 1rem; color: var(--forest-deep);
  }
  .head-meta {
    display: flex; flex-wrap: wrap; gap: 1.5rem;
    font-size: 0.875rem; color: var(--text-mid); font-weight: 500;
  }
  .head-meta-item { display: flex; align-items: center; gap: 0.5rem; }
  .head-meta-item svg { width: 14px; height: 14px; color: var(--forest-mid); }
  .scope-tag { color: var(--forest); font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; font-weight: 600; }

  .stats {
    display: flex; gap: 0;
    border: 2px solid var(--forest);
    border-radius: 10px; overflow: hidden;
    background: var(--surface);
  }
  .stat {
    padding: 1rem 1.5rem; text-align: right;
    min-width: 110px;
  }
  .stat + .stat { border-left: 2px solid var(--forest); }
  .stat-label {
    display: block; font-size: 0.625rem; font-weight: 700;
    color: var(--forest-mid); text-transform: uppercase;
    letter-spacing: 0.2em; margin-bottom: 0.5rem;
  }
  .stat-value {
    font-family: 'Source Serif 4', serif;
    font-size: 2.5rem; font-weight: 700; line-height: 1; color: var(--forest-deep);
  }
  .stat-value.accent { color: var(--forest); }

  .grid-12 { display: grid; grid-template-columns: repeat(12, 1fr); gap: 3rem; }
  .col-must { grid-column: span 5; }
  .col-noted { grid-column: span 7; }
  @media (max-width: 900px) {
    .col-must, .col-noted { grid-column: span 12; }
    .head-title { font-size: 2.25rem; }
    .grid-12 { gap: 2rem; }
  }

  .section-label { display: flex; align-items: center; gap: 0.875rem; margin-bottom: 1.75rem; }
  .section-label-text {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.28em;
    text-transform: uppercase; white-space: nowrap;
  }
  .section-label-text.primary { color: var(--forest-deep); }
  .section-label-text.secondary { color: var(--forest-mid); }
  .section-rule { height: 2px; flex: 1; background: var(--forest); }
  .section-rule.soft { background: var(--forest-soft); }

  /* MUST READ cards — heavier borders */
  .must-card {
    position: relative; overflow: hidden;
    border: 2px solid var(--forest);
    border-radius: 10px;
    background: var(--surface);
    padding: 1.75rem;
    transition: all 0.2s; margin-bottom: 1.5rem;
    box-shadow: 0 2px 0 var(--forest-deep);
  }
  .must-card:hover {
    border-color: var(--forest-deep);
    box-shadow: 0 6px 20px -6px rgba(16,48,34,0.25);
    transform: translateY(-1px);
  }
  .must-card .accent-bar {
    position: absolute; left: 0; top: 0; bottom: 0; width: 6px;
    background: var(--forest);
  }

  .must-meta-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; margin-bottom: 1rem;
  }
  .must-meta-left {
    font-family: 'JetBrains Mono', monospace; font-size: 0.6875rem;
    color: var(--forest-deep); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
  }

  /* SCORE BOX */
  .score-box {
    display: inline-flex; align-items: baseline; gap: 0.375rem;
    padding: 0.45rem 0.75rem; border-radius: 6px;
    border: 2px solid; font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
  }
  .score-box .score-num { font-size: 1rem; line-height: 1; }
  .score-box .score-of { font-size: 0.625rem; opacity: 0.7; }
  .score-box[data-score="5"] { background: var(--s5-bg); color: var(--s5-fg); border-color: var(--s5-bd); }
  .score-box[data-score="4"] { background: var(--s4-bg); color: var(--s4-fg); border-color: var(--s4-bd); }
  .score-box[data-score="3"] { background: var(--s3-bg); color: var(--s3-fg); border-color: var(--s3-bd); }
  .score-box[data-score="2"] { background: var(--s2-bg); color: var(--s2-fg); border-color: var(--s2-bd); }
  .score-box[data-score="1"] { background: var(--s1-bg); color: var(--s1-fg); border-color: var(--s1-bd); }

  /* Study-type badges */
  .badges-row { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
  .badge {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.3rem 0.55rem; border-radius: 4px; font-size: 0.625rem;
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    border: 1.5px solid;
  }
  .badge-type {
    background: #F1F2EC; border-color: var(--border); color: var(--text-mid);
  }
  .badge-novel {
    background: var(--forest);
    border-color: var(--forest-deep);
    color: #ffffff;
  }
  .badge-novel::before {
    content: '✦'; font-size: 0.75rem; line-height: 1;
  }

  .must-title {
    font-family: 'Source Serif 4', serif;
    font-size: 1.2rem; font-weight: 700; line-height: 1.32; color: var(--forest-deep);
    margin-bottom: 0.5rem; letter-spacing: -0.01em;
  }
  .must-authors {
    font-size: 0.75rem; color: var(--text-dim); margin-bottom: 1rem; line-height: 1.5;
    padding-bottom: 1rem; border-bottom: 1px dashed var(--border-soft);
  }
  .must-authors .senior { color: var(--forest-mid); font-weight: 600; }

  /* Structured summary sections */
  .summary-section { margin-bottom: 0.875rem; font-size: 0.875rem; line-height: 1.6; color: var(--text-mid); }
  .summary-section:last-child { margin-bottom: 0; }
  .summary-section h4 {
    font-family: 'Inter', sans-serif;
    font-size: 0.625rem; font-weight: 700;
    color: var(--forest); text-transform: uppercase;
    letter-spacing: 0.18em; margin-bottom: 0.35rem;
  }

  .must-rationale {
    margin-top: 1.25rem;
    display: flex; align-items: flex-start; gap: 0.625rem;
    padding: 0.875rem 1rem;
    background: var(--forest-tint);
    border: 1.5px solid var(--forest-line);
    border-left-width: 4px;
    border-radius: 6px;
    font-size: 0.8125rem; color: var(--forest-deep); line-height: 1.55;
  }
  .must-rationale svg { width: 15px; height: 15px; margin-top: 1px; color: var(--forest); flex-shrink: 0; }
  .must-rationale strong { color: var(--forest-deep); font-weight: 700; }

  .must-actions {
    margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;
  }
  .link-pill {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.6875rem; font-weight: 600; color: var(--forest-deep);
    text-decoration: none; padding: 0.45rem 0.7rem;
    border: 1.5px solid var(--forest-line); border-radius: 4px;
    background: var(--surface); transition: all 0.15s;
  }
  .link-pill:hover { color: #fff; border-color: var(--forest); background: var(--forest); }
  .link-pill svg { width: 11px; height: 11px; }

  /* NOTED — also bumped border weight */
  .noted-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .noted-item {
    border: 1.5px solid var(--border);
    border-left: 4px solid var(--forest-soft);
    border-radius: 6px;
    background: var(--surface);
    padding: 1rem 1.125rem;
    transition: all 0.15s; cursor: pointer;
  }
  .noted-item:hover {
    border-left-color: var(--forest);
    border-color: var(--forest-line);
    transform: translateX(2px);
  }
  .noted-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.55rem; flex-wrap: wrap; }
  .score-chip {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 26px; height: 24px; padding: 0 0.45rem;
    border-radius: 4px; border: 1.5px solid;
    font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 700;
  }
  .score-chip[data-score="5"] { background: var(--s5-bg); color: var(--s5-fg); border-color: var(--s5-bd); }
  .score-chip[data-score="4"] { background: var(--s4-bg); color: var(--s4-fg); border-color: var(--s4-bd); }
  .score-chip[data-score="3"] { background: var(--s3-bg); color: var(--s3-fg); border-color: var(--s3-bd); }
  .score-chip[data-score="2"] { background: var(--s2-bg); color: var(--s2-fg); border-color: var(--s2-bd); }
  .score-chip[data-score="1"] { background: var(--s1-bg); color: var(--s1-fg); border-color: var(--s1-bd); }
  .badge-type-mini {
    font-family: 'Inter', sans-serif; font-size: 0.5625rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--text-mid); padding: 0.2rem 0.45rem;
    background: #F1F2EC; border: 1px solid var(--border-soft); border-radius: 3px;
  }
  .noted-title {
    font-family: 'Source Serif 4', serif;
    font-size: 1rem; font-weight: 700; color: var(--forest-deep);
    line-height: 1.32; margin-bottom: 0.5rem;
  }
  .noted-summary {
    font-size: 0.8125rem; color: var(--text-mid); line-height: 1.6;
  }
  .noted-source {
    margin-top: 0.625rem; font-family: 'JetBrains Mono', monospace;
    font-size: 0.5625rem; color: var(--forest-mid); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.15em;
    padding-top: 0.5rem; border-top: 1px dashed var(--border-soft);
  }

  footer.report-footer {
    margin-top: 4rem; padding-top: 1.5rem; border-top: 2px solid var(--forest);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.625rem; color: var(--forest-mid); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.18em; flex-wrap: wrap; gap: 1rem;
  }

  .policy-section { margin-bottom: 3rem; }
  .policy-empty {
    font-size: 0.875rem; color: var(--text-dim);
    font-style: italic; padding: 0.5rem 0;
  }
  .policy-grid { display: flex; flex-direction: column; gap: 1rem; }
  .policy-card {
    border: 1.5px solid var(--border);
    border-left: 4px solid var(--forest-soft);
    border-radius: 8px; background: var(--surface);
    padding: 1.125rem 1.25rem;
  }
  .policy-card.policy-critical {
    border: 2px solid var(--forest);
    border-left: 6px solid var(--forest);
    background: var(--forest-tint);
  }
  .policy-meta {
    display: flex; align-items: center; gap: 0.625rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.6875rem;
    margin-bottom: 0.5rem;
  }
  .policy-source {
    font-weight: 700; color: var(--forest-deep);
    padding: 0.2rem 0.45rem; background: var(--surface);
    border: 1.5px solid var(--forest-line); border-radius: 4px;
    letter-spacing: 0.05em;
  }
  .policy-tier {
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    padding: 0.2rem 0.45rem; border-radius: 4px; border: 1.5px solid;
  }
  .policy-tier-critical { background: var(--forest); color: #fff; border-color: var(--forest-deep); }
  .policy-tier-notable { background: #F1F2EC; color: var(--text-mid); border-color: var(--border); }
  .policy-date { color: var(--text-dim); margin-left: auto; }
  .policy-title {
    font-family: 'Source Serif 4', serif;
    font-size: 1.0625rem; font-weight: 700; color: var(--forest-deep);
    margin-bottom: 0.4rem; line-height: 1.3;
  }
  .policy-summary {
    font-size: 0.875rem; color: var(--text-mid);
    line-height: 1.55; margin-bottom: 0.75rem;
  }
</style>
</head>
<body>
<div class="paper-grain"></div>

<header>
  <div class="container header-inner">
    <div class="logo-block">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/></svg>
      </div>
      <div>
        <div class="brand-title">ENT / Airway / Face Digest</div>
        <div class="brand-sub">Daily Literature Brief</div>
      </div>
    </div>
    <div class="header-right">
      <div class="status-pill">
        <div class="pulse-dot"></div>
        <span class="mono" style="font-size:0.6875rem;letter-spacing:0.12em;">RUN OK · {{ run_time_et }}</span>
      </div>
    </div>
  </div>
</header>

<main>
  <div class="container">

    <div class="report-head">
      <div>
        <div class="head-status">
          <div class="pulse-dot"></div>
          <span class="head-status-text">Curated by Sonnet 4.6</span>
        </div>
        <h1 class="head-title">{{ digest_date_long }}</h1>
        <div class="head-meta">
          <div class="head-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <span>EDAT range: {{ edat_from }} – {{ edat_to }}</span>
          </div>
          <div class="head-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
            <span class="scope-tag">{{ buckets_run }} PubMed queries · ENT/Airway/Face/Peds</span>
          </div>
        </div>
      </div>

      <div class="stats">
        <div class="stat">
          <span class="stat-label">Surfaced</span>
          <span class="stat-value">{{ surfaced_count }}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Made Cut</span>
          <span class="stat-value accent">{{ made_cut_count }}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Must Read</span>
          <span class="stat-value">{{ must_read_count }}</span>
        </div>
      </div>
    </div>

    <section class="policy-section">
      <div class="section-label">
        <div class="section-rule"></div>
        <span class="section-label-text primary">Policy &amp; Practice Updates · {{ policy_updates|length }}</span>
      </div>
      {% if policy_updates %}
        <div class="policy-grid">
          {% for item in policy_updates %}
          <div class="policy-card policy-{{ item.tier|lower }}">
            <div class="policy-meta">
              <span class="policy-source">{{ item.source }}</span>
              <span class="policy-tier policy-tier-{{ item.tier|lower }}">{{ item.tier }}</span>
              <span class="policy-date">{{ item.date }}</span>
            </div>
            <h3 class="policy-title">{{ item.title }}</h3>
            <p class="policy-summary">{{ item.summary }}</p>
            <a class="link-pill" href="{{ item.url }}" target="_blank" rel="noopener">Source ↗</a>
          </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="policy-empty">No new policy updates this week.</p>
      {% endif %}
    </section>

    <div class="grid-12">

      <!-- MUST READ -->
      <section class="col-must">
        <div class="section-label">
          <div class="section-rule"></div>
          <span class="section-label-text primary">Must Read · {{ must_read_count }}</span>
        </div>

        {% for paper in must_read %}
<div class="must-card">
  <div class="accent-bar"></div>
  <div class="must-meta-row">
    <span class="must-meta-left">{{ '%02d'|format(loop.index) }} · {{ paper.journal }}{% if paper.journal_impact_factor %} · IF {{ paper.journal_impact_factor }}{% endif %}</span>
    <div class="score-box" data-score="{{ paper.score }}">
      <span class="score-num">{{ paper.score }}</span><span class="score-of">/5</span>
    </div>
  </div>
  <div class="badges-row">
    {% for badge in paper.badges %}<span class="badge badge-type">{{ badge }}</span>{% endfor %}
    {% if paper.novel_technique %}<span class="badge badge-novel">Novel Technique</span>{% endif %}
  </div>
  <h3 class="must-title">{{ paper.title }}</h3>
  <div class="must-authors">{{ paper.authors_display|safe }}{% if paper.senior_author %} … <span class="senior">{{ paper.senior_author }}{% if paper.senior_affiliation %} (senior, {{ paper.senior_affiliation }}){% endif %}</span>{% endif %}</div>
  {% for section in paper.summary_sections %}
  <div class="summary-section">
    <h4>{{ section.label }}</h4>
    <p>{{ section.text }}</p>
  </div>
  {% endfor %}
  <div class="must-rationale">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    <span><strong>Why score {{ paper.score }}:</strong> {{ paper.rationale }}</span>
  </div>
  <div class="must-actions">
    <a class="link-pill" href="https://pubmed.ncbi.nlm.nih.gov/{{ paper.pmid }}" target="_blank" rel="noopener">PMID {{ paper.pmid }}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
    </a>
    {% if paper.doi %}<a class="link-pill" href="https://doi.org/{{ paper.doi }}" target="_blank" rel="noopener">DOI</a>{% endif %}
    <button class="link-pill copy-pmid" data-pmid="{{ paper.pmid }}" type="button">📋 Copy PMID</button>
  </div>
</div>
{% endfor %}
      </section>

      <!-- NOTED -->
      <section class="col-noted">
        <div class="section-label">
          <span class="section-label-text secondary">Noted · {{ noted|length }}</span>
          <div class="section-rule soft"></div>
        </div>

        <div class="noted-grid">
{% for paper in noted %}
<div class="noted-item">
  <div class="noted-head">
    <span class="score-chip" data-score="{{ paper.score }}">{{ paper.score }}</span>
    {% for badge in paper.badges %}<span class="badge-type-mini">{{ badge }}</span>{% endfor %}
  </div>
  <div class="noted-title">{{ paper.title }}</div>
  <p class="noted-summary">{{ paper.summary }}</p>
  <div class="noted-source">{{ paper.journal }} · PMID {{ paper.pmid }} · <button class="copy-pmid noted-copy" data-pmid="{{ paper.pmid }}" type="button">📋 Copy</button></div>
</div>
{% endfor %}
        </div>

        <footer class="report-footer">
          <span>Run · 2026-05-15 · 06:03 ET</span>
          <div style="display:flex;gap:1.5rem;">
            <span style="display:flex;align-items:center;gap:0.5rem;"><span style="width:8px;height:8px;background:var(--forest);border-radius:50%;display:inline-block;"></span> Sonnet 4.6</span>
            <span style="display:flex;align-items:center;gap:0.5rem;"><span style="width:8px;height:8px;background:var(--forest-soft);border-radius:50%;display:inline-block;"></span> Source: PubMed</span>
          </div>
        </footer>

      </section>
    </div>
  </div>
</main>

<script type="application/json" id="digest-data">
{{ digest_json|safe }}
</script>
<script>
(function() {
  document.querySelectorAll('.copy-pmid').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var pmid = btn.getAttribute('data-pmid');
      navigator.clipboard.writeText(pmid).then(function() {
        var original = btn.textContent;
        btn.textContent = '✓ Copied!';
        setTimeout(function() { btn.textContent = original; }, 1500);
      });
    });
  });
})();
</script>
</body>
</html>
